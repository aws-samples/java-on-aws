      "apps/unicorn-store-javax/src/main/java/com/unicorn/store/utils/Math.java": {
        "content": {
          "text": "package com.unicorn.store.utils;\nimport java.math.BigDecimal;\n\npublic class Math {\n    Boolean bool = new Boolean(true);\n    Byte b = new Byte(\"1\");\n    Character c = new Character('c');\n    Double d = new Double(1.0);\n    Float f = new Float(1.1f);\n    Long l = new Long(1L);\n    Short sh = new Short(\"12\");\n    Short s3 = 3;\n    Integer i = new Integer(1);\n\n    void divide(){\n        BigDecimal bd = BigDecimal.valueOf(10);\n        BigDecimal bd2 = BigDecimal.valueOf(3);\n        bd.divide(bd2, BigDecimal.ROUND_DOWN);\n        bd.divide(bd2, 1);\n        bd.divide(bd2, 1, BigDecimal.ROUND_DOWN);\n        bd.divide(bd2, 1,1);\n        bd.setScale(2,1);\n    }\n}",
