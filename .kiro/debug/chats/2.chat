      "type": "file",
      "path": "infra/scripts/setup/ide.sh",
      "staticContent": "<file name=\"infra/scripts/setup/ide.sh\" language=\"shellscript\" >\n<content>\n#!/bin/bash\nset -e\n\n# IDE setup script - runs as ec2-user\necho \"Starting IDE setup at $(date)\"\n\n# Update system packages\necho \"Updating system packages...\"\nsudo yum update -y\n\n# Create environment folder for workshop\necho \"Creating ~/environment folder...\"\nmkdir -p ~/environment\necho \"Environment folder created at: $(pwd)/environment\"\n\n# Log completion\necho \"IDE setup completed successfully at $(date)\"\necho \"Ready for workshop activities!\"\n</content>\n</file>"
    },
    {
      "type": "file",
      "path": "infra/cdk/src/main/java/sample/com/constructs/Ide.java",
      "staticContent": "<file name=\"infra/cdk/src/main/java/sample/com/constructs/Ide.java\" language=\"java\" >\n<content>\npackage sample.com.constructs;\n\nimport software.amazon.awscdk.Aws;\nimport software.amazon.awscdk.CfnOutput;\nimport software.amazon.awscdk.CfnWaitCondition;\nimport software.amazon.awscdk.CfnWaitConditionHandle;\nimport software.amazon.awscdk.CustomResource;\nimport software.amazon.awscdk.Duration;\nimport software.amazon.awscdk.Fn;\nimport software.amazon.awscdk.RemovalPolicy;\nimport software.amazon.awscdk.services.cloudfront.AllowedMethods;\nimport software.amazon.awscdk.services.cloudfront.BehaviorOptions;\nimport software.amazon.awscdk.services.cloudfront.CachePolicy;\nimport software.amazon.awscdk.services.cloudfront.Distribution;\nimport software.amazon.awscdk.services.cloudfront.HttpVersion;\nimport software.amazon.awscdk.services.cloudfront.OriginProtocolPolicy;\nimport software.amazon.awscdk.services.cloudfront.OriginRequestPolicy;\nimport software.amazon.awscdk.services.cloudfront.ViewerProtocolPolicy;\nimport software.amazon.awscdk.services.cloudfront.origins.HttpOrigin;\nimport software.amazon.awscdk.services.cloudfront.origins.HttpOriginProps;\nimport software.amazon.awscdk.services.ec2.*;\nimport software.amazon.awscdk.services.iam.*;\nimport software.amazon.awscdk.services.secretsmanager.Secret;\nimport software.amazon.awscdk.services.secretsmanager.SecretStringGenerator;\nimport software.amazon.awscdk.services.ssm.CfnDocument;\nimport software.constructs.Construct;\n\nimport java.util.ArrayList;\nimport java.util.Arrays;\nimport java.util.HashMap;\nimport java.util.List;\nimport java.util.Map;\n\npublic class Ide extends Construct {\n    private final SecurityGroup ideSecurityGroup;\n    private final SecurityGroup ideInternalSecurityGroup;\n    private final Secret ideSecretsManagerPassword;\n\n    public Ide(final Construct scope, final String id, final IVpc vpc, final Roles roles) {\n        super(scope, id);\n\n        String instanceName = \"ide\";\n\n        // Set up wait condition handle for bootstrap completion (needed for User Data)\n        var waitHandle = CfnWaitConditionHandle.Builder.create(this, \"IdeBootstrapWaitConditionHandle\")\n            .build();\n\n        // Use static CloudFront prefix list ID (more reliable than Lambda lookup)\n        String cloudFrontPrefixListId = \"pl-3b927c52\"; // CloudFront origin-facing prefix list\n\n        // Create security group for IDE access (CloudFront only)\n        this.ideSecurityGroup = SecurityGroup.Builder.create(this, \"IdeSecurityGroup\")\n            .vpc(vpc)\n            .allowAllOutbound(true)\n            .securityGroupName(instanceName + \"-cloudfront-ide-sg\")\n            .description(\"IDE security group\")\n            .build();\n\n        ideSecurityGroup.addIngressRule(\n            Peer.prefixList(cloudFrontPrefixListId),\n            Port.tcp(80),\n            \"HTTP from CloudFront only\"\n        );\n\n        // Internal security group for VPC communication\n        this.ideInternalSecurityGroup = SecurityGroup.Builder.create(this, \"IdeInternalSecurityGroup\")\n            .vpc(vpc)\n            .allowAllOutbound(false)\n            .securityGroupName(instanceName + \"-internal-sg\")\n            .description(\"IDE internal security group\")\n            .build();\n\n        ideInternalSecurityGroup.getConnections().allowInternally(\n            Port.allTraffic(),\n            \"Allow all internal traffic\"\n        );\n\n        // Create instance profile\n        var instanceProfile = InstanceProfile.Builder.create(this, \"IdeInstanceProfile\")\n            .role(roles.getWorkshopRole())\n            .instanceProfileName(roles.getWorkshopRole().getRoleName())\n            .build();\n\n        // Create Elastic IP\n        var elasticIP = CfnEIP.Builder.create(this, \"IdeElasticIP\")\n            .domain(\"vpc\")\n            .build();\n\n        // Create instance launcher Lambda function\n        var launcherFunction = new WorkshopLambda(this, \"LauncherFunction\",\n            WorkshopLambdaProps.builder()\n                .sourceFile(\"/lambda/launcher.py\")\n                .functionName(instanceName + \"-launcher\")\n                .timeout(Duration.minutes(5))\n                .role(roles.getLambdaRole())\n                .build());\n\n        // Get public subnets\n        var publicSubnets = vpc.selectSubnets(SubnetSelection.builder()\n            .subnetType(SubnetType.PUBLIC)\n            .build());\n\n        // Build security group IDs list\n        List<String> securityGroupIds = new ArrayList<>();\n        securityGroupIds.add(ideSecurityGroup.getSecurityGroupId());\n        securityGroupIds.add(ideInternalSecurityGroup.getSecurityGroupId());\n\n        // Create User Data for bootstrap with CloudWatch logging\n        var userData = UserData.forLinux();\n        userData.addCommands(\n            \"#!/bin/bash\",\n            \"set -e\",\n            \"\",\n            \"# Generate unique log group name with runtime timestamp\",\n            \"LOG_GROUP_NAME=\\\"ide-bootstrap-$(date +%Y%m%d-%H%M%S)\\\"\",\n            \"echo \\\"Bootstrap logs will be written to CloudWatch log group: $LOG_GROUP_NAME\\\"\",\n            \"\",\n            \"# Install and configure CloudWatch agent for logging\",\n            \"echo \\\"Installing CloudWatch agent...\\\"\",\n            \"yum install -y amazon-cloudwatch-agent\",\n            \"\",\n            \"# Create CloudWatch agent configuration\",\n            \"cat > /opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json << 'EOF'\",\n            \"{\",\n            \"  \\\"logs\\\": {\",\n            \"    \\\"logs_collected\\\": {\",\n            \"      \\\"files\\\": {\",\n            \"        \\\"collect_list\\\": [\",\n            \"          {\",\n            \"            \\\"file_path\\\": \\\"/var/log/bootstrap.log\\\",\",\n            \"            \\\"log_group_name\\\": \\\"$LOG_GROUP_NAME\\\",\",\n            \"            \\\"log_stream_name\\\": \\\"{instance_id}\\\",\",\n            \"            \\\"retention_in_days\\\": 7\",\n            \"          }\",\n            \"        ]\",\n            \"      }\",\n            \"    }\",\n            \"  }\",\n            \"}\",\n            \"EOF\",\n            \"\",\n            \"# Start CloudWatch agent\",\n            \"/opt/aws/amazon-cloudwatch-agent/bin/amazon-cloudwatch-agent-ctl \\\\\",\n            \"  -a fetch-config -m ec2 -c file:/opt/aws/amazon-cloudwatch-agent/etc/amazon-cloudwatch-agent.json -s\",\n            \"\",\n            \"# Redirect all bootstrap output to log file and console\",\n            \"exec > >(tee -a /var/log/bootstrap.log)\",\n            \"exec 2>&1\",\n            \"\",\n            \"echo \\\"Bootstrap started at $(date) - Logging to $LOG_GROUP_NAME\\\"\",\n            \"\",\n            \"# Clone workshop setup scripts from the new-ws-infra branch\",\n            \"echo \\\"Cloning workshop setup scripts...\\\"\",\n            \"cd /tmp\",\n            \"git clone -b new-ws-infra https://github.com/aws-samples/java-on-aws.git workshop-setup\",\n            \"cd workshop-setup\",\n            \"\",\n            \"# Make scripts executable\",\n            \"chmod +x infra/scripts/setup/*.sh\",\n            \"\",\n            \"# Run the IDE setup script as ec2-user\",\n            \"echo \\\"Running IDE setup script as ec2-user...\\\"\",\n            \"sudo -u ec2-user bash infra/scripts/setup/ide.sh\",\n            \"\",\n            \"echo \\\"Bootstrap completed successfully at $(date)\\\"\",\n            \"\",\n            \"# Signal CloudFormation completion\",\n            \"/opt/aws/bin/cfn-signal -e $? --stack \" + Aws.STACK_NAME +\n            \" --resource IdeInstance --region \" + Aws.REGION\n        );\n\n        // Create EC2 instance via Custom Resource with failover support\n        var ec2InstanceResource = CustomResource.Builder.create(this, \"IdeEC2InstanceResource\")\n            .serviceToken(launcherFunction.getFunction().getFunctionArn())\n            .properties(Map.of(\n                \"SubnetIds\", String.join(\",\", publicSubnets.getSubnetIds()),\n                \"InstanceTypes\", \"m5.xlarge,m6i.xlarge,t3.xlarge\",\n                \"ImageId\", MachineImage.latestAmazonLinux2023().getImage(this).getImageId(),\n                \"SecurityGroupIds\", String.join(\",\", securityGroupIds),\n                \"IamInstanceProfileArn\", instanceProfile.getInstanceProfileArn(),\n                \"VolumeSize\", \"50\",\n                \"InstanceName\", instanceName,\n                \"UserData\", Fn.base64(userData.render())\n            ))\n            .build();\n\n        String instanceId = ec2InstanceResource.getAttString(\"InstanceId\");\n\n        // Associate Elastic IP with the instance\n        var ipAssociation = CfnEIPAssociation.Builder.create(this, \"IdeEipAssociation\")\n            .allocationId(elasticIP.getAttrAllocationId())\n            .instanceId(instanceId)\n            .build();\n\n        // Create public DNS name from EIP\n        String publicDnsName = Fn.join(\"\", List.of(\n            \"ec2-\",\n            Fn.select(0, Fn.split(\".\", elasticIP.getAttrPublicIp())),\n            \"-\",\n            Fn.select(1, Fn.split(\".\", elasticIP.getAttrPublicIp())),\n            \"-\",\n            Fn.select(2, Fn.split(\".\", elasticIP.getAttrPublicIp())),\n            \"-\",\n            Fn.select(3, Fn.split(\".\", elasticIP.getAttrPublicIp())),\n            \".compute-1.amazonaws.com\"\n        ));\n\n        // Create CloudFront distribution\n        var distribution = Distribution.Builder.create(this, \"IdeDistribution\")\n            .defaultBehavior(BehaviorOptions.builder()\n                .origin(new HttpOrigin(publicDnsName,\n                    HttpOriginProps.builder()\n                        .protocolPolicy(OriginProtocolPolicy.HTTP_ONLY)\n                        .httpPort(80)\n                        .build()))\n                .allowedMethods(AllowedMethods.ALLOW_ALL)\n                .cachePolicy(CachePolicy.CACHING_DISABLED)\n                .originRequestPolicy(OriginRequestPolicy.ALL_VIEWER)\n                .viewerProtocolPolicy(ViewerProtocolPolicy.ALLOW_ALL)\n                .build())\n            .httpVersion(HttpVersion.HTTP2)\n            .build();\n\n        distribution.applyRemovalPolicy(RemovalPolicy.DESTROY);\n        distribution.getNode().addDependency(ipAssociation);\n\n        // Create password secret\n        this.ideSecretsManagerPassword = Secret.Builder.create(this, \"IdePasswordSecret\")\n            .generateSecretString(SecretStringGenerator.builder()\n                .excludePunctuation(true)\n                .passwordLength(32)\n                .generateStringKey(\"password\")\n                .includeSpace(false)\n                .secretStringTemplate(\"{\\\"password\\\":\\\"\\\"}\")\n                .excludeCharacters(\"\\\"@/\\\\\\\\\")\n                .build())\n            .secretName(instanceName + \"-password\")\n            .build();\n\n        ideSecretsManagerPassword.grantRead(roles.getWorkshopRole());\n\n        var waitCondition = CfnWaitCondition.Builder.create(this, \"IdeBootstrapWaitCondition\")\n            .count(1)\n            .handle(waitHandle.getRef())\n            .timeout(\"1800\") // 30 minutes\n            .build();\n        waitCondition.getNode().addDependency(ec2InstanceResource);\n\n        // Outputs\n        CfnOutput.Builder.create(this, \"IdeUrl\")\n            .value(\"https://\" + distribution.getDistributionDomainName())\n            .description(\"Workshop IDE URL\")\n            .exportName(instanceName + \"-url\")\n            .build();\n\n        CfnOutput.Builder.create(this, \"IdePassword\")\n            .value(ideSecretsManagerPassword.secretValueFromJson(\"password\").unsafeUnwrap())\n            .description(\"Workshop IDE Password\")\n            .exportName(instanceName + \"-password\")\n            .build();\n    }\n\n    public SecurityGroup getIdeSecurityGroup() {\n        return ideSecurityGroup;\n    }\n\n    public SecurityGroup getIdeInternalSecurityGroup() {\n        return ideInternalSecurityGroup;\n    }\n\n\n\n\n}\n</content>\n<issues>\n<issue-0>\nSaw Information: \"xlarge\": Unknown word.\n\n\nxlarge\n</issue-0>\n\n<issue-1>\nSaw Information: \"xlarge\": Unknown word.\n\n\nxlarge\n</issue-1>\n\n<issue-2>\nSaw Information: \"xlarge\": Unknown word.\n\n\nxlarge\n</issue-2>\n</issues>\n</file>"
    },
    {
      "type": "file",
      "path": "infra/cdk/src/main/resources/lambda/launcher.py",
      "staticContent": "<file name=\"infra/cdk/src/main/resources/lambda/launcher.py\" language=\"python\" >\n<content>\nimport json\nimport boto3\nimport logging\nfrom typing import Dict, List, Any, Optional\n\nlogger = logging.getLogger()\nlogger.setLevel(logging.INFO)\n\ndef lambda_handler(event: Dict[str, Any], context: Any) -> Dict[str, Any]:\n    \"\"\"\n    EC2 instance launching Lambda function with multi-AZ and multi-instance-type failover.\n    Provides robust instance launching with automatic failover across availability zones\n    and instance types when capacity is not available.\n    \"\"\"\n    try:\n        logger.info(f\"Received event: {json.dumps(event, default=str)}\")\n\n        ec2 = boto3.client('ec2')\n\n        # Extract and validate parameters\n        ami_id = event.get('ImageId')\n        subnet_ids = _parse_comma_separated(event.get('SubnetIds', ''))\n        instance_types = _parse_comma_separated(event.get('InstanceTypes', 't3.medium'))\n        security_group_ids = _parse_comma_separated(event.get('SecurityGroupIds', ''))\n        instance_profile_arn = event.get('IamInstanceProfileArn')\n        volume_size = int(event.get('VolumeSize', 20))\n        instance_name = event.get('InstanceName', 'workshop-instance')\n        user_data = event.get('UserData', '')\n\n        # Validation\n        if not ami_id:\n            raise ValueError(\"ImageId is required\")\n        if not subnet_ids:\n            raise ValueError(\"At least one SubnetId is required\")\n        if not security_group_ids:\n            raise ValueError(\"At least one SecurityGroupId is required\")\n\n        # Try each combination of subnet and instance type\n        last_error = None\n        for subnet_id in subnet_ids:\n            for instance_type in instance_types:\n                try:\n                    logger.info(f\"Attempting to launch {instance_type} in subnet: {subnet_id}\")\n\n                    launch_params = {\n                        'ImageId': ami_id,\n                        'MinCount': 1,\n                        'MaxCount': 1,\n                        'InstanceType': instance_type,\n                        'SubnetId': subnet_id,\n                        'SecurityGroupIds': security_group_ids,\n                        'UserData': user_data,\n                        'BlockDeviceMappings': [{\n                            'DeviceName': '/dev/xvda',\n                            'Ebs': {\n                                'VolumeSize': volume_size,\n                                'VolumeType': 'gp3',\n                                'DeleteOnTermination': True\n                            }\n                        }],\n                        'TagSpecifications': [{\n                            'ResourceType': 'instance',\n                            'Tags': [\n                                {'Key': 'Name', 'Value': instance_name},\n                                {'Key': 'Workshop', 'Value': 'true'}\n                            ]\n                        }]\n                    }\n\n                    if instance_profile_arn:\n                        launch_params['IamInstanceProfile'] = {'Arn': instance_profile_arn}\n\n                    response = ec2.run_instances(**launch_params)\n                    instance = response['Instances'][0]\n                    instance_id = instance['InstanceId']\n\n                    logger.info(f\"Successfully launched {instance_type} instance: {instance_id} in {subnet_id}\")\n\n                    return {\n                        'InstanceId': instance_id,\n                        'InstanceType': instance_type,\n                        'SubnetId': subnet_id,\n                        'AvailabilityZone': instance['Placement']['AvailabilityZone'],\n                        'Status': 'SUCCESS'\n                    }\n\n                except Exception as launch_error:\n                    error_msg = str(launch_error)\n                    logger.warning(f\"Failed to launch {instance_type} in {subnet_id}: {error_msg}\")\n                    last_error = launch_error\n\n                    # Check if it's a capacity issue and continue to next combination\n                    if any(phrase in error_msg.lower() for phrase in [\n                        'insufficient capacity', 'capacity not available',\n                        'unsupported', 'invalid instance type'\n                    ]):\n                        continue\n                    else:\n                        # For other errors, still try other combinations but log more details\n                        logger.error(f\"Non-capacity error for {instance_type} in {subnet_id}: {error_msg}\")\n                        continue\n\n        # If we get here, all combinations failed\n        raise RuntimeError(f\"Failed to launch instance with any combination of subnets {subnet_ids} \"\n                          f\"and instance types {instance_types}. Last error: {str(last_error)}\")\n\n    except Exception as e:\n        logger.error(f\"Error launching instance: {str(e)}\")\n        # Re-raise the exception to signal CloudFormation stack failure\n        # This is critical - if we can't launch the instance, the entire deployment is pointless\n        raise RuntimeError(f\"Failed to launch workshop instance: {str(e)}\")\n\ndef _parse_comma_separated(value: str) -> List[str]:\n    \"\"\"Parse comma-separated string into list, handling empty strings.\"\"\"\n    if not value or not value.strip():\n        return []\n    return [item.strip() for item in value.split(',') if item.strip()]\n</content>\n<issues>\n<issue-0>\nSaw Information: \"xvda\": Unknown word.\n\n\nxvda\n</issue-0>\n</issues>\n</file>"
    },
