ild.amazonaws.com\n        Version: \"2012-10-17\"\n      ManagedPolicyArns:\n        - Fn::Join:\n            - \"\"\n            - - \"arn:\"\n              - Ref: AWS::Partition\n              - :iam::aws:policy/PowerUserAccess\n  RolesCodeBuildRoleDefaultPolicy62DE7EED:\n    Type: AWS::IAM::Policy\n    Properties:\n      PolicyDocument:\n        Statement:\n          - Action: ec2:CreateNetworkInterfacePermission\n            Condition:\n              StringEquals:\n                ec2:Subnet:\n                  - Fn::Join:\n                      - \"\"\n                      - - \"arn:\"\n                        - Ref: AWS::Partition\n                        - \":ec2:\"\n                        - Ref: AWS::Region\n                        - \":\"\n                        - Ref: AWS::AccountId\n                        - :subnet/\n                        - Ref: VpcWorkshopVpcPrivateSubnet1SubnetCE870430\n                  - Fn::Join:\n                      - \"\"\n                      - - \"arn:\"\n                        - Ref: AWS::Partition\n                        - \":ec2:\"\n                        - Ref: AWS::Region\n                        - \":\"\n                        - Ref: AWS::AccountId\n                        - :subnet/\n                        - Ref: VpcWorkshopVpcPrivateSubnet2SubnetA1F06CF5\n                ec2:AuthorizedService: codebuild.amazonaws.com\n            Effect: Allow\n            Resource:\n              Fn::Join:\n                - \"\"\n                - - \"arn:\"\n                  - Ref: AWS::Partition\n                  - \":ec2:\"\n                  - Ref: AWS::Region\n                  - \":\"\n                  - Ref: AWS::AccountId\n                  - :network-interface/*\n          - Action:\n              - logs:CreateLogGroup\n              - logs:CreateLogStream\n              - logs:PutLogEvents\n            Effect: Allow\n            Resource:\n              - Fn::Join:\n                  - \"\"\n                 