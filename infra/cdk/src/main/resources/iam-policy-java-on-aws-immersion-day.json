{
	"Version": "2012-10-17",
	"Statement": [
		{
			"Sid": "MarketplaceSubscribeClaude45Opus45Sonnet4Sonnet",
            "Effect": "Allow",
            "Action": [
                "aws-marketplace:Subscribe"
            ],
            "Resource": "*",
            "Condition": {
                "Null": {
                    "aws-marketplace:ProductId": "false"
                },
                "ForAllValues:StringEquals": {
                    "aws-marketplace:ProductId": [
						"prod-jhuafngbly644",
						"prod-mxcfnwvpd6kb4",
						"prod-4pmewlybdftbs"
                    ]
                }
            }
        },
        {
            "Effect": "Allow",
            "Action": [
                "aws-marketplace:Unsubscribe",
                "aws-marketplace:ViewSubscriptions",
				"bedrock:*"
            ],
            "Resource": "*"
        },
		{
			"Sid": "AllowedServices",
			"Effect": "Allow",
			"Action": [
				"apigateway:*",
				"application-signals:*",
				"cloudformation:*",
				"cloudwatch:*",
				"codewhisperer:*",
				"ec2:*",
				"ecr:*",
				"ecs:*",
				"eks:*",
				"elasticloadbalancing:*",
				"events:*",
				"lambda:*",
				"logs:*",
				"q:*",
				"rds:*",
				"s3:*",
				"secretsmanager:*",
				"ssm:*",
				"sts:*",
				"tag:*",
				"xray:*"
			],
			"Resource": "*"
		},
		{
			"Sid": "PassRole",
			"Effect": "Allow",
			"Action": [
				"iam:PassRole"
			],
			"Resource": [
				"arn:aws:iam::{{.AccountId}}:role/unicorn*",
				"arn:aws:iam::{{.AccountId}}:role/jvm-analysis-service*"
			]
		},
		{
			"Sid": "DenyXXLInstances",
			"Effect": "Deny",
			"Action": "ec2:RunInstances",
			"Condition": {
			"StringLike": {
				"ec2:InstanceType": [
				"*4xlarge",
				"*6xlarge",
				"*8xlarge",
				"*9xlarge",
				"*10xlarge",
				"*12xlarge",
				"*16xlarge",
				"*18xlarge",
				"*24xlarge",
				"f1*",
				"x1*",
				"z1*",
				"*metal"
				]
			}
			},
			"Resource": ["arn:aws:ec2:*:*:instance/*"]
		},
		{
			"Sid": "DenyReservations",
			"Effect": "Deny",
			"Action": [
				"ec2:ModifyReservedInstances",
				"ec2:PurchaseHostReservation",
				"ec2:PurchaseReservedInstancesOffering",
				"ec2:PurchaseScheduledInstances",
				"rds:PurchaseReservedDBInstancesOffering",
				"dynamodb:PurchaseReservedCapacityOfferings"
			],
			"Resource": "*"
		}
	]
  }